{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Orbital — Platform Overview",
  "uid": "orbital-overview",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(django_http_requests_total, namespace)",
        "current": { "value": "orbital" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(django_http_requests_total{namespace=\"$namespace\"}[2m]))",
          "legendFormat": "Total req/s"
        },
        {
          "expr": "sum(rate(django_http_requests_total{namespace=\"$namespace\", status=~\"2..\"}[2m]))",
          "legendFormat": "2xx"
        },
        {
          "expr": "sum(rate(django_http_requests_total{namespace=\"$namespace\", status=~\"5..\"}[2m]))",
          "legendFormat": "5xx errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#E24B4A", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "Error rate (% of requests)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * sum(rate(django_http_requests_total{namespace=\"$namespace\", status=~\"5..\"}[5m])) / sum(rate(django_http_requests_total{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "Error rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.1  },
              { "color": "red",    "value": 0.5  }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Latency percentiles",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(django_http_requests_latency_seconds_bucket{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(django_http_requests_latency_seconds_bucket{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(django_http_requests_latency_seconds_bucket{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "Pod count (ready vs desired)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{namespace=\"$namespace\", deployment=\"orbital\"}",
          "legendFormat": "Ready"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 2    },
              { "color": "green",  "value": 3    }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Memory usage per pod",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 8, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"$namespace\", container=\"orbital\"} / 1024 / 1024",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "MiB",
          "custom": { "lineWidth": 1 }
        }
      }
    },
    {
      "id": 6,
      "title": "CPU usage per pod",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 8, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", container=\"orbital\"}[2m]) * 1000",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "millicores"
        }
      }
    },
    {
      "id": 7,
      "title": "DB query rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (alias) (rate(django_db_execute_total{namespace=\"$namespace\"}[2m]))",
          "legendFormat": "{{ alias }} queries/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 8,
      "title": "DB query p95 latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(django_db_execute_latency_seconds_bucket{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "p95 DB latency"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 9,
      "title": "Top 10 slowest views (p95)",
      "type": "table",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, view) (rate(django_http_requests_latency_seconds_bucket{namespace=\"$namespace\"}[10m]))))",
          "legendFormat": "{{ view }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ]
}
