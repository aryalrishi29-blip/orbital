# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# Django
DJANGO_SECRET_KEY=your-secret-key-here          # python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database (Postgres)
DB_NAME=myapp
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# AWS (used by GitHub Actions — do not set locally)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# EC2 (used by GitHub Actions deploy job)
EC2_HOST=
EC2_SSH_PRIVATE_KEY=
